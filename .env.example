# Query settings
# TOPIC_QUERY is a global fallback used when a source-specific query is empty.
TOPIC_QUERY=
ARXIV_QUERY=cat:cs.AI+OR+cat:cs.LG+OR+cat:cs.CL+OR+cat:physics.med-ph
MEDRXIV_QUERY=category:epidemiology+infectious_diseases
PUBMED_QUERY=("machine learning"[Title/Abstract]) AND ("radiology"[Title/Abstract])
SCHOLAR_QUERY="clinical foundation model" OR "medical multimodal model"
ENABLE_SOURCES=arxiv,medrxiv,pubmed,scholar
DAYS_BACK=1
MAX_RESULTS_PER_QUERY=20
MAX_TOTAL_RESULTS=60
REPORT_TIMEZONE=Asia/Shanghai

# Runtime settings
REQUEST_TIMEOUT=20
SEND_EMPTY_DIGEST=false
DRY_RUN=false
USER_AGENT=daily-paper-bot/1.0 (+github-action)

# SMTP settings
SMTP_SERVER=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=your_username
SMTP_PASSWORD=your_password
EMAIL_SENDER=bot@example.com
EMAIL_RECEIVERS=you@example.com,coauthor@example.com

# Optional keys
NCBI_API_KEY=
SERPAPI_API_KEY=
